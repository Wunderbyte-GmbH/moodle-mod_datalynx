{{!
    @template mod_datalynx/default_control_bar

    Displays the default modern and responsive control bar for datalynx views.

    Example context (json):
    {
        "viewtype": "grid",
        "hasviewsmenu": true,
        "hasfiltersmenu": true,
        "hasquicksearch": true,
        "hasquickperpage": true,
        "hasactions": true,
        "actionshtml": "<a href='#'>Add new entry</a>",
        "entriesclass": "mod-datalynx-grid-entries row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4",
        "haspagingbar": true
    }
}}
<div class="datalynx-view-container container-fluid px-0">
    <!-- Main Controls Header Card -->
    <div class="datalynx-controls card mb-4 border shadow-sm bg-light rounded">
        <div class="card-body p-3">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                <!-- Navigation & Filtering -->
                <div class="d-flex flex-wrap align-items-center gap-2 datalynx-controls-group">
                    {{#hasviewsmenu}}
                        <div class="datalynx-control datalynx-control-views">##viewsmenu##</div>
                    {{/hasviewsmenu}}
                    {{#hasfiltersmenu}}
                        <div class="datalynx-control datalynx-control-filters">##filtersmenu##</div>
                    {{/hasfiltersmenu}}
                </div>
                <!-- Search & Per Page -->
                <div class="d-flex flex-wrap align-items-center gap-2 datalynx-controls-group">
                    {{#hasquicksearch}}
                        <div class="datalynx-control datalynx-control-search">##quicksearch##</div>
                    {{/hasquicksearch}}
                    {{#hasquickperpage}}
                        <div class="datalynx-control datalynx-control-perpage">##quickperpage##</div>
                    {{/hasquickperpage}}
                </div>
            </div>
        </div>
    </div>

    <!-- Actions Bar (Add entry, exports, import) -->
    {{#hasactions}}
        <div class="datalynx-actions d-flex flex-wrap align-items-center gap-2 mb-3">
            {{{actionshtml}}}
        </div>
    {{/hasactions}}

    <!-- Entries Container -->
    <div class="{{entriesclass}}" data-region="{{viewtype}}-view-browser">
        ##entries##
    </div>

    <!-- Paging Bar -->
    {{#haspagingbar}}
        <div class="datalynx-paging-wrapper d-flex justify-content-center mt-4">
            <div class="datalynx-control datalynx-control-paging">##pagingbar##</div>
        </div>
    {{/haspagingbar}}
</div>
