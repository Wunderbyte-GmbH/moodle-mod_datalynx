{{!
    @template mod_datalynx/tabular_view_browser
}}
<div class="mod-datalynx-tabular-view-browser"
     data-datalynxid="{{datalynxid}}"
     data-viewid="{{viewid}}"
     data-viewtype="{{viewtype}}">
    {{#hasentries}}
        {{#groups}}
            {{#hasname}}
                <h3 class="main">{{name}}</h3>
            {{/hasname}}
            <div class="entriesview">
                <div class="no-overflow">
                    <table class="generaltable">
                        <thead>
                            <tr>
                                {{#columns}}
                                    <th class="header {{columnclass}}{{#islast}} lastcol{{/islast}}" style="text-align:{{alignstyle}};" scope="col">{{{headerhtml}}}</th>
                                {{/columns}}
                            </tr>
                        </thead>
                        <tbody>
                            {{#rows}}
                                <tr class="{{rowclass}}" data-entryid="{{id}}">
                                    {{#cells}}
                                        <td class="cell {{columnclass}}{{#islast}} lastcol{{/islast}}" style="text-align:{{alignstyle}};">{{{valuehtml}}}</td>
                                    {{/cells}}
                                </tr>
                            {{/rows}}
                        </tbody>
                    </table>
                </div>
            </div>
        {{/groups}}
    {{/hasentries}}
    {{^hasentries}}
        <div class="alert alert-info">{{emptycontent}}</div>
    {{/hasentries}}
</div>
